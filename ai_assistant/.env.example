# =============================================================
# 필수 (MVP 구동에 반드시 필요)
# =============================================================

# --- Telegram ---
# @BotFather 에서 /newbot 으로 생성 후 토큰 발급
TELEGRAM_BOT_TOKEN=

# 봇을 사용할 수 있는 Telegram user ID (쉼표로 구분)
# 본인 user id 확인: https://t.me/userinfobot 에 /start
# 비워두면 누구나 사용 가능 (프로덕션 비권장)
ALLOWED_TELEGRAM_USER_IDS=

# --- Anthropic (Claude API) ---
# https://console.anthropic.com/ 에서 발급
ANTHROPIC_API_KEY=

# 모델: claude-haiku-4-5 (기본, 저렴·빠름) / claude-sonnet-4-6 (중간) / claude-opus-4-7 (최고급)
CLAUDE_MODEL=claude-haiku-4-5

# --- Google Calendar ---
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# (application type: Desktop app) 에서 받은 JSON 파일 경로
GOOGLE_CREDENTIALS_PATH=credentials.json

# 최초 OAuth 후 토큰 저장 경로 (자동 생성)
GOOGLE_TOKEN_PATH=token.json

# "primary" = 인증된 계정의 기본 캘린더
# 팀 공용 캘린더를 쓰려면 해당 캘린더의 ID를 입력
CALENDAR_ID=primary

# =============================================================
# 선택 (활성화하려는 기능만 채우세요)
# =============================================================

# --- Google Drive (주간 리포트 업로드 대상 폴더) ---
# 비우면 My Drive 루트에 저장. 폴더 ID 확인: 드라이브에서 폴더 열면 URL 끝 부분
# 예) https://drive.google.com/drive/folders/1abcDEF...  ← "1abcDEF..." 가 폴더 ID
DRIVE_FOLDER_ID=

# --- Airwallex (주간 리포트에 수익/지출 자동 포함) ---
# https://www.airwallex.com/app → Developer → API Keys 에서 발급
# 둘 다 비우면 자금 섹션 생략됨
AIRWALLEX_CLIENT_ID=
AIRWALLEX_API_KEY=
# 기본값은 글로벌 엔드포인트. 지역별 엔드포인트 필요시 변경
# AIRWALLEX_BASE_URL=https://api.airwallex.com

# --- F&B 트렌드 브리프 (매주 월 9시 자동, Claude Web Search 사용) ---
# 조사할 국가 목록. 쉼표 구분. 비우면 트렌드 자동 리포트 비활성화
TREND_COUNTRIES=싱가포르,베트남,일본,미국,인도네시아
TRENDS_REPORT_DAY=mon
TRENDS_REPORT_HOUR=9
TRENDS_REPORT_MINUTE=0

# --- 주간 리포트 스케줄 (기본: 매주 금요일 17:00 KST) ---
WEEKLY_REPORT_DAY=fri
WEEKLY_REPORT_HOUR=17
WEEKLY_REPORT_MINUTE=0

# 리포트를 전송받을 Telegram 채팅 ID. 비우면 ALLOWED_TELEGRAM_USER_IDS 의 첫번째로 전송됨
WEEKLY_REPORT_CHAT_ID=

# =============================================================
# 공통 / 고급 설정
# =============================================================
DEFAULT_TIMEZONE=Asia/Seoul
DB_PATH=assistant.db

# 대화 히스토리를 몇 개까지 Claude에 넘길지
HISTORY_LIMIT=40
